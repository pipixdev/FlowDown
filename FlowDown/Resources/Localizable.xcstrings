            "state" : "translated",
            "value" : "Settings backup is only supported when using UserDefaults storage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La copia de seguridad de ajustes solo se admite cuando se usa el almacenamiento UserDefaults."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sauvegarde des réglages est uniquement prise en charge avec le stockage UserDefaults."
          }
        },
        "ja" : {
