    "Use the model to classify content into one of the provided candidates. If the model cannot decide, the first candidate is returned." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Modell nutzen, um den Inhalt einem der angegebenen Kandidaten zuzuordnen. Kann es nicht entscheiden, wird der erste Kandidat zurückgegeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the model to classify content into one of the provided candidates. If the model cannot decide, the first candidate is returned."
          }
