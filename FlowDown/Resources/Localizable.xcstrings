          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please rewrite the following content in a more friendly and approachable tone, making it easy to understand and engaging."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reescribe el contenido en un tono más amable y cercano, fácil de entender y atractivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réécrivez le contenu suivant dans un ton plus amical et accessible, facile à comprendre et engageant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の内容を、より親しみやすく理解しやすいトーンで書き直してください。"
