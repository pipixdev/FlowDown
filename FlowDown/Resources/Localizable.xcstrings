        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einen neuen Titel für die Unterhaltung setzen. Leer lassen, um unverändert zu lassen. Deaktiviert die automatische Umbenennung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
