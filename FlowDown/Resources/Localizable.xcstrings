          }
        }
      }
    },
    "Settings backups only include configurable preferences and model selections. Conversations and local model weights remain separate." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einstellungs-Backups enthalten nur konfigurierbare Präferenzen und Modellauswahlen. Unterhaltungen und lokale Modellgewichte bleiben getrennt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Settings backups only include configurable preferences and model selections. Conversations and local model weights remain separate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las copias de seguridad de ajustes solo incluyen preferencias configurables y selecciones de modelos. Las conversaciones y los pesos de modelos locales permanecen aparte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les sauvegardes des réglages incluent uniquement les préférences configurables et les sélections de modèles. Les conversations et les poids des modèles locaux restent séparés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定バックアップには、設定可能なプリファレンスとモデル選択のみが含まれます。会話やローカルモデルの重みは含まれません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설정 백업에는 설정 가능한 환경설정과 모델 선택만 포함됩니다. 대화와 로컬 모델 가중치는 별도로 유지됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置备份仅包含可配置偏好和模型选择。会话记录和本地模型权重不会包含在内。"
          }
        }
      }
    },
