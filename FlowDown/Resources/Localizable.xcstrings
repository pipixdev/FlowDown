    "Change application behavior, manage language model providers, and get control of your data." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändere das Verhalten der Anwendung, verwalte Sprachmodell-Anbieter und kontrolliere deine Daten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change application behavior, manage language model providers, and get control of your data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia el comportamiento de la aplicación, gestiona proveedores de modelos de lenguaje y controla tus datos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifiez le comportement de l’application, gérez les fournisseurs de modèles et contrôlez vos données."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリの挙動を変更し、言語モデルプロバイダを管理し、データを制御します。"
          }
        },
