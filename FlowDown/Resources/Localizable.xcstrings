    "Enable iCloud sync to keep data consistent across your devices. Turning off does not delete existing data." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere iCloud-Sync, um Daten über deine Geräte hinweg konsistent zu halten. Deaktivieren löscht keine vorhandenen Daten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable iCloud sync to keep data consistent across your devices. Turning off does not delete existing data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa la sincronización con iCloud para mantener los datos consistentes entre tus dispositivos. Desactivarla no elimina los datos existentes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez la synchro iCloud pour garder vos données cohérentes sur vos appareils. La désactivation ne supprime pas les données existantes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 同期で複数デバイスのデータを一致させます。オフにしても既存データは削除されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기기 간 데이터 일치를 위해 iCloud 동기화를 켜세요. 끄더라도 기존 데이터는 삭제되지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用 iCloud 同步以保持多设备数据一致。关闭不会删除现有数据。"
          }
        }
      }
    },
