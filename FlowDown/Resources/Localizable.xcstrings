    "Importing a database backup will replace all current conversations, memories, and cloud model settings. This action cannot be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Import eines Datenbank-Backups werden alle aktuellen Unterhaltungen, Erinnerungen und Cloud-Modell-Einstellungen ersetzt. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importing a database backup will replace all current conversations, memories, and cloud model settings. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importar una copia de seguridad de la base de datos reemplazará todas las conversaciones, recuerdos y configuraciones de modelos en la nube actuales. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’import d’une sauvegarde de base de données remplacera toutes les conversations, mémoires et réglages de modèles cloud actuels. Cette action est irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データベースバックアップをインポートすると、現在の会話、メモリー、クラウドモデル設定がすべて置き換わります。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "데이터베이스 백업을 가져오면 현재 모든 대화, 메모리, 클라우드 모델 설정이 대체됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "导入数据库备份将替换当前的所有对话、记忆以及云模型设置。此操作无法撤销。"
          }
        }
      }
    },
