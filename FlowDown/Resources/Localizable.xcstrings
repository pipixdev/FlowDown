    "Turning off sync only pauses future updates. Existing data stays in place. Re‑enable later to fetch and resume syncing." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sync ausschalten pausiert nur zukünftige Updates. Bestehende Daten bleiben erhalten. Später wieder aktivieren, um Updates abzurufen und die Synchronisierung fortzusetzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turning off sync only pauses future updates. Existing data stays in place. Re‑enable later to fetch and resume syncing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactivar la sincronización solo pausa futuras actualizaciones. Los datos existentes permanecen. Reactiva después para reanudar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactiver la synchro ne fait que mettre en pause les futures mises à jour. Les données existantes restent en place. Réactivez plus tard pour reprendre la synchro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同期をオフにすると今後の更新が停止するだけで、既存データは残ります。再度有効にすれば取得と同期を再開できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동기화를 끄면 향후 업데이트만 중단됩니다. 기존 데이터는 그대로이며, 나중에 다시 켜면 최신 상태를 가져와 동기화를 재개합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭同步仅暂停后续更新，现有数据保持不变。稍后重新开启将先获取最新状态再继续同步。"
          }
        }
      }
    },
