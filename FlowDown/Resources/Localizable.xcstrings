    },
    "Pages that exceed the model's context length will be ignored. Too many pages may increase network usage and slow down inference." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seiten, die die Kontextlänge des Modells überschreiten, werden ignoriert. Zu viele Seiten können den Netzwerkverbrauch erhöhen und die Inferenz verlangsamen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pages that exceed the model's context length will be ignored. Too many pages may increase network usage and slow down inference."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las páginas que excedan la longitud de contexto del modelo se ignorarán. Demasiadas páginas pueden aumentar el uso de red y ralentizar la inferencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les pages dépassant la longueur de contexte du modèle seront ignorées. Trop de pages peuvent augmenter l’usage réseau et ralentir l’inférence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルのコンテキスト長を超えるページは無視されます。ページが多すぎると通信量が増え、推論が遅くなる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델 컨텍스트 길이를 초과하는 페이지는 무시됩니다. 페이지가 많으면 네트워크 사용량이 늘고 추론이 느려질 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "超出模型上下文长度的页面将被丢弃。过多的页面可能使用更多的流量并减慢对话速度。"
          }
        }
      }
    },
