    "Enable this to automatically collapse reasoning content after the reasoning is completed. This is useful for keeping the chat interface clean and focused on the final response." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere dies, um Begründungsinhalte nach Abschluss automatisch einzuklappen. Hilft, das Chat-Interface sauber zu halten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable this to automatically collapse reasoning content after the reasoning is completed. This is useful for keeping the chat interface clean and focused on the final response."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa esto para contraer automáticamente el contenido de razonamiento después de completarlo. Es útil para mantener la interfaz limpia y centrada en la respuesta final."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez cette option pour replier automatiquement le contenu de raisonnement une fois terminé. Utile pour garder l’interface de chat claire et centrée sur la réponse finale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "推論完了後に推論内容を自動で折りたたみます。チャット画面をスッキリさせ、最終回答に集中するのに役立ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추론이 완료된 후 자동으로 추론 내용을 접습니다. 채팅 화면을 깔끔하고 최종 응답에 집중할 수 있게 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用这个选项将在推理结束时自动折叠思考内容。"
          }
        }
      }
    },
    "Enable this to require Command + Enter to send message. On touch devices, you will need to tap the send button manually." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere dies, damit zum Senden Command + Enter erforderlich ist. Auf Touch-Geräten musst du dann den Senden-Button tippen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable this to require Command + Enter to send message. On touch devices, you will need to tap the send button manually."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa esto para exigir Command + Enter al enviar mensajes. En dispositivos táctiles tendrás que tocar el botón de enviar manualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez cette option pour exiger Commande + Entrée pour envoyer le message. Sur les appareils tactiles, vous devrez appuyer sur le bouton d’envoi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "送信時に Command + Enter を要求します。タッチデバイスでは送信ボタンを手動でタップしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메시지를 보내려면 Command + Enter가 필요하도록 설정합니다. 터치 기기에서는 보내기 버튼을 직접 탭해야 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当启用这个选项，需要同时按下 Command + 回车 才会发送消息。在触摸设备上，则需要点击发送按钮。"
          }
        }
      }
    },
