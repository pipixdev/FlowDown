          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All memory data is stored locally on your device. Export operations allow you to backup your memory data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los datos de memoria se guardan localmente en tu dispositivo. Las exportaciones te permiten hacer copias de seguridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
