    },
    "Analyze the conversation and generate a reusable chat template. Extract the core purpose, create a concise name, suggest an appropriate emoji, and write a system prompt that captures the essence of the conversation pattern." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analysiere die Unterhaltung und erstelle eine wiederverwendbare Chat-Vorlage. Extrahiere den Kernzweck, finde einen prägnanten Namen, schlage ein passendes Emoji vor und schreibe einen Systemprompt, der das Muster der Unterhaltung einfängt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analyze the conversation and generate a reusable chat template. Extract the core purpose, create a concise name, suggest an appropriate emoji, and write a system prompt that captures the essence of the conversation pattern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analiza la conversación y genera una plantilla de chat reutilizable. Extrae el propósito principal, crea un nombre conciso, sugiere un emoji adecuado y redacta una instrucción de sistema que capture la esencia del patrón conversacional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analysez la conversation et générez un modèle de chat réutilisable. Extrayez l’objectif principal, créez un nom concis, suggérez un emoji approprié et rédigez une invite système qui capture l’essence du schéma de conversation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "会話を分析して再利用可能なチャットテンプレートを生成してください。目的を抽出し、簡潔な名前と適切な絵文字を提案し、会話パターンの本質を捉えるシステムプロンプトを書いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "대화를 분석해 재사용 가능한 채팅 템플릿을 생성하세요. 핵심 목적을 추출하고 간결한 이름을 만들며 적절한 이모지를 제안하고, 대화 패턴의 본질을 담은 시스템 프롬프트를 작성하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分析对话并生成可复用的聊天模板。提取核心目的，创建一个简洁的名称，建议一个合适的表情符号，并撰写一个系统提示，以捕捉对话模式的精髓。"
          }
        }
      }
    },
    "Animals & Nature" : {
      "comment" : "Emoji Category",
      "localizations" : {
        "de" : {
