        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rewrite the following content so it reads professional, confident, and concise while preserving the original meaning. Reply with the revised text only."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reescribe el siguiente contenido para que suene profesional, seguro y conciso manteniendo el significado original. Responde solo con el texto revisado."
