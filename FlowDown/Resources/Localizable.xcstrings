    "Get control of your data, configure cloud sync, export database or reset the app." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Behalte die Kontrolle über deine Daten, konfiguriere Cloud-Sync, exportiere die Datenbank oder setze die App zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get control of your data, configure cloud sync, export database or reset the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toma el control de tus datos, configura la sincronización en la nube, exporta la base de datos o restablece la app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prenez le contrôle de vos données, configurez la synchronisation cloud, exportez la base de données ou réinitialisez l’app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データを管理し、クラウド同期を設定、データベースをエクスポート、またはアプリをリセットします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "데이터를 제어하고 클라우드 동기화를 구성하며 데이터베이스를 내보내거나 앱을 초기화하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "管理你的数据，配置云同步，导出数据库，重置软件。"
          }
        }
      }
    },
