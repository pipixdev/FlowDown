    "The model is used for visual input when the current model does not support it. It will extract information before using the current model for inference." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Modell wird für visuelle Eingaben genutzt, wenn das aktuelle Modell dies nicht unterstützt. Es extrahiert Informationen, bevor das aktuelle Modell für die Inferenz verwendet wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The model is used for visual input when the current model does not support it. It will extract information before using the current model for inference."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modelo se usa para entrada visual cuando el modelo actual no la soporta. Extraerá información antes de usar el modelo actual para inferencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce modèle est utilisé pour l’entrée visuelle quand le modèle actuel ne la supporte pas. Il extrait l’information avant d’utiliser le modèle actuel pour l’inférence."
          }
        },
        "ja" : {
          "stringUnit" : {
