    "Are you sure you want to clean the cache? This will also delete partial downloads." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchtest du den Cache wirklich leeren? Dadurch werden auch Teil-Downloads gelöscht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to clean the cache? This will also delete partial downloads."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres limpiar la caché? Esto también borrará descargas parciales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment vider le cache ? Cela supprimera aussi les téléchargements partiels."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャッシュを削除しますか？未完了のダウンロードも削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캐시를 정리하시겠습니까? 부분 다운로드도 삭제됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你确定要清理缓存吗？这包括未完成的下载项。"
          }
        }
      }
    },
    "Are you sure you want to delete all conversations and related data?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchtest du wirklich alle Unterhaltungen und zugehörigen Daten löschen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete all conversations and related data?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres borrar todas las conversaciones y datos relacionados?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment supprimer toutes les conversations et les données associées ?"
