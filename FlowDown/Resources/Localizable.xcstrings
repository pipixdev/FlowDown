    "Configure global prompt, adjust parameters when inferencing." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Globalen Prompt konfigurieren, Parameter bei der Inferenz anpassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure global prompt, adjust parameters when inferencing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura la instrucción global y ajusta parámetros durante la inferencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurez l’invite globale et ajustez les paramètres lors de l’inférence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "グローバルプロンプトを設定し、推論時のパラメータを調整します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "글로벌 프롬프트를 구성하고 추론 시 매개변수를 조정하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "配置全局提示词，调整推理参数。"
          }
        }
      }
    },
    "Configure inference-specific body fields here. The json key-value pairs you enter are merged into every request." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inferenzspezifische Body-Felder hier konfigurieren. Die eingegebenen JSON-Schlüssel/Werte werden in jede Anfrage übernommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure inference-specific body fields here. The json key-value pairs you enter are merged into every request."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura aquí los campos de cuerpo específicos para la inferencia. Las parejas clave-valor JSON que introduzcas se incorporan a cada solicitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurez ici les champs de corps spécifiques à l’inférence. Les paires clé-valeur JSON que vous saisissez sont fusionnées dans chaque requête."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "推論専用のボディフィールドをここで設定します。入力した JSON キーと値はすべてのリクエストにマージされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추론 전용 바디 필드를 여기서 설정하세요. 입력한 JSON 키-값 쌍은 모든 요청에 병합됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 JSON 键值对配置推理请求的载荷，并在请求时合并配置。"
          }
        }
      }
    },
    "Configure tool settings, choose search engine for internet searches, adding custom tools." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tool-Einstellungen konfigurieren, Suchmaschine für Internetsuchen wählen, eigene Tools hinzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure tool settings, choose search engine for internet searches, adding custom tools."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura ajustes de herramientas, elige el motor de búsqueda para Internet y añade herramientas personalizadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurez les paramètres des outils, choisissez le moteur de recherche pour Internet et ajoutez des outils personnalisés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツール設定を構成し、検索エンジンを選び、カスタムツールを追加します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도구 설정을 구성하고 인터넷 검색 엔진을 선택하며 사용자 정의 도구를 추가합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "配置工具设置，选择网络搜索引擎，添加自定义工具。"
          }
        }
      }
    },
