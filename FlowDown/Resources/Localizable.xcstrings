        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请用更友好和亲切的语气重写以下内容，使其易于理解且引人入胜。"
          }
        }
      }
    },
    "Please rewrite the following content in a more professional tone, using formal language and appropriate terminology." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte den folgenden Inhalt in professionellerem Ton umschreiben und formelle Sprache sowie passende Terminologie nutzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please rewrite the following content in a more professional tone, using formal language and appropriate terminology."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reescribe el contenido con un tono más profesional, usando lenguaje formal y la terminología adecuada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réécrivez le contenu suivant dans un ton plus professionnel, avec un langage formel et une terminologie appropriée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の内容をよりプロフェッショナルなトーンで、適切な用語とフォーマルな言葉遣いで書き直してください。"
          }
        },
        "ko" : {
