    "Play audio feedback during inference output. This helps determine if a task is complete when running in the background." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio-Feedback während der Inferenzausgabe abspielen. Dies hilft festzustellen, ob eine Aufgabe im Hintergrund abgeschlossen ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play audio feedback during inference output. This helps determine if a task is complete when running in the background."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reproduce retroalimentación de audio durante la salida de inferencia. Esto ayuda a determinar si una tarea está completa cuando se ejecuta en segundo plano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jouer un retour audio pendant la sortie d'inférence. Cela aide à déterminer si une tâche est terminée lors de l'exécution en arrière-plan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "推論出力中にオーディオフィードバックを再生します。これにより、バックグラウンドで実行中にタスクが完了したかどうかを判断できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추론 출력 중 오디오 피드백을 재생합니다. 이는 백그라운드에서 실행 중일 때 작업이 완료되었는지 확인하는 데 도움이 됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在推理输出时播放音频反馈。这有助于在后台运行时确定任务是否完成。"
          }
        }
      }
    },
    "Please add more details and expand on the following content to provide additional information and context." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte füge mehr Details hinzu und erweitere den folgenden Inhalt, um zusätzliche Informationen und Kontext bereitzustellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please add more details and expand on the following content to provide additional information and context."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade más detalles y amplía el siguiente contenido para aportar información y contexto adicionales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez plus de détails et développez le contenu suivant pour fournir informations et contexte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の内容に詳細を追加し、情報と文脈を補足してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추가 정보와 맥락을 위해 다음 내용을 더 자세히 확장해 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请添加更多细节并扩展以下内容，提供额外的信息和上下文。"
          }
        }
      }
    },
    "Please add some models to use. You can choose to download models, or use cloud model from well known service providers." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte füge Modelle hinzu. Du kannst Modelle herunterladen oder Cloud-Modelle bekannter Anbieter verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please add some models to use. You can choose to download models, or use cloud model from well known service providers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade algunos modelos para usar. Puedes descargar modelos o usar modelos en la nube de proveedores reconocidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez des modèles à utiliser. Vous pouvez en télécharger ou utiliser des modèles cloud de fournisseurs connus."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "利用するモデルを追加してください。モデルをダウンロードするか、クラウド提供のモデルを利用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용할 모델을 추가하세요. 모델을 다운로드하거나 잘 알려진 서비스 제공자의 클라우드 모델을 사용할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请添加一些模型。你可以从下载一个模型，或者添加来自常见服务提供商的云端模型。"
          }
        }
      }
    },
