        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avertissement"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "경고"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告"
          }
        }
      }
    },
    "We are not responsible for the model you are about to download. If we are unable to load this model, the app may crash. Do you want to continue?\n\nEstimated download size: %@" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir übernehmen keine Verantwortung für das Modell, das du herunterladen willst. Wenn wir es nicht laden können, kann die App abstürzen. Möchtest du fortfahren?\n\nGeschätzte Downloadgröße: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We are not responsible for the model you are about to download. If we are unable to load this model, the app may crash. Do you want to continue?\n\nEstimated download size: %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No somos responsables del modelo que vas a descargar. Si no podemos cargarlo, la app podría fallar. ¿Quieres continuar?\n\nTamaño de descarga estimado: %@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous ne sommes pas responsables du modèle que vous allez télécharger. Si nous ne pouvons pas le charger, l’app peut planter. Voulez-vous continuer ?\n\nTaille de téléchargement estimée : %@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これからダウンロードするモデルについて当方は責任を負いません。読み込めない場合、アプリがクラッシュする可能性があります。続行しますか？\n\n推定ダウンロードサイズ: %@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다운로드하려는 모델에 대해 책임을 지지 않습니다. 이 모델을 불러오지 못하면 앱이 충돌할 수 있습니다. 계속하시겠습니까?\n\n예상 다운로드 크기: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们不对你即将下载的模型负责。如果此模型加载失败，软件可能会崩溃。你确定要继续？\n\n预计的下载大小为：%@"
          }
        }
      }
    },
    "We are unable to process the link you tapped, either it is invalid or not supported." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der angeklickte Link kann nicht verarbeitet werden, er ist ungültig oder wird nicht unterstützt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We are unable to process the link you tapped, either it is invalid or not supported."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No podemos procesar el enlace que tocaste; es inválido o no compatible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de traiter le lien sur lequel vous avez appuyé, il est invalide ou non pris en charge."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タップしたリンクは無効か未対応のため処理できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "탭한 링크를 처리할 수 없습니다. 잘못되었거나 지원되지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此链接已损坏或不受支持，无法打开。"
          }
        }
      }
    },
    "We cannot determine the context length supported by the model. Please choose the correct configuration here. Configuring a context length smaller than the capacity can save costs. A context that is too long may be truncated during inference." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können die vom Modell unterstützte Kontextlänge nicht bestimmen. Bitte hier die korrekte Konfiguration wählen. Eine kürzere Kontextlänge spart Kosten; ein zu langer Kontext kann bei der Inferenz gekürzt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We cannot determine the context length supported by the model. Please choose the correct configuration here. Configuring a context length smaller than the capacity can save costs. A context that is too long may be truncated during inference."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No podemos determinar la longitud de contexto que admite el modelo. Elige la configuración correcta aquí. Configurar una longitud menor puede ahorrar costos. Un contexto demasiado largo puede truncarse durante la inferencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous ne pouvons pas déterminer la longueur de contexte prise en charge par le modèle. Choisissez la bonne configuration ici. Un contexte plus court que la capacité peut réduire les coûts. Un contexte trop long peut être tronqué lors de l’inférence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルがサポートするコンテキスト長を判定できません。ここで適切に設定してください。容量より小さく設定するとコスト節約になり、長すぎると推論時に切り捨てられる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델이 지원하는 컨텍스트 길이를 알 수 없습니다. 여기서 올바르게 설정하세요. 용량보다 작게 설정하면 비용을 절약할 수 있고, 너무 길면 추론 중 잘릴 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们无法确认模型所支持的上下文长度，请在此处选择正确的配置。配置小于容量的上下文可以节省开销。过长的上下文可能会在推理时截断。"
          }
        }
      }
    },
    "We cannot determine whether this model includes additional capabilities. However, if supported, features such as visual recognition can be enabled manually here. Please note that if the model does not actually support these capabilities, attempting to enable them may result in errors." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir können nicht feststellen, ob dieses Modell zusätzliche Fähigkeiten besitzt. Falls unterstützt, können Funktionen wie visuelle Erkennung hier manuell aktiviert werden. Beachte, dass bei nicht unterstützten Fähigkeiten Fehler auftreten können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We cannot determine whether this model includes additional capabilities. However, if supported, features such as visual recognition can be enabled manually here. Please note that if the model does not actually support these capabilities, attempting to enable them may result in errors."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No podemos determinar si este modelo incluye capacidades adicionales. Si están soportadas, puedes habilitar funciones como reconocimiento visual manualmente aquí. Si el modelo no las soporta realmente, habilitarlas puede causar errores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous ne pouvons pas déterminer si ce modèle inclut des capacités supplémentaires. Si elles sont prises en charge, des fonctionnalités comme la reconnaissance visuelle peuvent être activées manuellement ici. Si le modèle ne les supporte pas réellement, leur activation peut provoquer des erreurs."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このモデルに追加機能があるか判断できません。対応していればここでビジュアル認識などを手動で有効化できますが、実際に非対応の場合エラーとなる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 모델이 추가 기능을 포함하는지 알 수 없습니다. 지원된다면 여기서 시각 인식 등 기능을 수동으로 켤 수 있습니다. 실제로 지원하지 않으면 오류가 발생할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们无法确认这个模型是否具备某些额外的功能。如果你确认此模型支持这些功能，你可以在这里手动开启。但需要注意，如果模型实际上不支持这些功能，尝试开启可能会导致错误。"
          }
        }
      }
    },
    "We have requested your system to prioritize local processing of your audio data. However, there still remains a possibility that your audio data may be sent to Apple’s servers for processing. We are unable to determine whether your data has been sent to Apple’s servers." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben dein System gebeten, deine Audiodaten vorrangig lokal zu verarbeiten. Es besteht jedoch die Möglichkeit, dass die Audiodaten zur Verarbeitung an Apples Server gesendet werden. Wir können nicht feststellen, ob deine Daten an Apple gesendet wurden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We have requested your system to prioritize local processing of your audio data. However, there still remains a possibility that your audio data may be sent to Apple’s servers for processing. We are unable to determine whether your data has been sent to Apple’s servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hemos solicitado al sistema priorizar el procesamiento local de tu audio. Aun así, podría enviarse a los servidores de Apple. No podemos determinar si tus datos se enviaron."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons demandé au système de privilégier le traitement local de vos données audio. Il reste toutefois possible qu’elles soient envoyées aux serveurs d’Apple pour traitement. Nous ne pouvons pas déterminer si vos données ont été envoyées aux serveurs d’Apple."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声データはローカル処理を優先するようシステムに依頼していますが、Apple のサーバーに送信される可能性があります。送信されたかどうかは判断できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오디오 데이터를 우선 로컬에서 처리하도록 시스템에 요청했습니다. 그러나 여전히 Apple 서버로 전송될 가능성이 있으며, 실제 전송 여부는 확인할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们已请求您的系统优先在本地处理您的音频数据。然而，您的音频数据仍有可能被发送到 Apple 的服务器进行处理。我们无法确定您的数据是否已被发送至 Apple 的服务器。"
          }
        }
      }
    },
    "We provided a comprehensive documentation to help you understand how to use this app effectively." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben eine umfassende Dokumentation bereitgestellt, um dir die effektive Nutzung der App zu erklären."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We provided a comprehensive documentation to help you understand how to use this app effectively."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hemos proporcionado una documentación completa para ayudarte a usar la app eficazmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous fournissons une documentation complète pour vous aider à utiliser efficacement l’app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリを有効に活用するための包括的なドキュメントを提供しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 앱을 효과적으로 사용하는 방법을 알 수 있도록 포괄적인 문서를 제공했습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们提供详细的用户手册来帮助你更好的理解并使用 FlowDown。"
          }
        }
      }
    },
    "We require LAN access to interact with local service providers. We do not collect any information from your LAN." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir benötigen LAN-Zugriff, um mit lokalen Diensten zu interagieren. Wir sammeln keine Informationen aus deinem LAN."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We requires LAN access for interact with local service providers. We do not collect any information from your LAN."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necesitamos acceso LAN para interactuar con proveedores locales. No recopilamos información de tu LAN."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons besoin de l’accès LAN pour interagir avec des fournisseurs locaux. Aucune information n’est collectée sur votre réseau local."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカルのサービスプロバイダと連携するため LAN アクセスが必要です。LAN の情報を収集することはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로컬 서비스 제공자와 상호작용하려면 LAN 접근이 필요합니다. LAN 정보는 수집하지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要本地网络访问权限来连接到你所请求的服务提供商。"
          }
        }
      }
    },
    "We strongly recommend that you do not enable this feature unless you are sure what you are doing. It may cause unexpected behavior and even data loss." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir raten dringend davon ab, diese Funktion zu aktivieren, sofern du nicht genau weißt, was du tust. Sie kann zu unerwartetem Verhalten und sogar Datenverlust führen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We strongly recommend that you do not enable this feature unless you are sure what you are doing. It may cause unexpected behavior and even data loss."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recomendamos encarecidamente no habilitar esta función salvo que sepas lo que haces. Puede causar comportamientos inesperados e incluso pérdida de datos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous déconseillons vivement d’activer cette fonctionnalité sans certitude : elle peut provoquer des comportements inattendus et même une perte de données."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "何をしているか確信がある場合を除き、この機能を有効にしないことを強く推奨します。予期しない動作やデータ損失の恐れがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "확신이 없다면 이 기능을 켜지 않는 것을 강력히 권장합니다. 예기치 못한 동작이나 데이터 손실이 발생할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们强烈建议您不要启用此功能，除非您明确知道自己在做什么。这可能导致意外行为，甚至造成数据丢失。"
          }
        }
      }
    },
    "We use calendar access to allow the assistant to view, create and modify events in your calendar. Calendar data is only accessed when you explicitly use calendar-related features." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir verwenden den Kalenderzugriff, damit der Assistent Termine ansehen, erstellen und bearbeiten kann. Auf Kalenderdaten wird nur zugegriffen, wenn du kalenderbezogene Funktionen ausdrücklich nutzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use calendar access to allow the assistant to view, create and modify events in your calendar. Calendar data is only accessed when you explicitly use calendar-related features."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usamos acceso al calendario para que el asistente vea, cree y modifique eventos. Solo se accede cuando usas funciones de calendario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous utilisons l’accès au calendrier pour permettre à l’assistant de voir, créer et modifier des événements. Les données du calendrier ne sont consultées que lorsque vous utilisez des fonctions liées au calendrier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カレンダーアクセスを用いてアシスタントがイベントの閲覧・作成・編集を行います。カレンダー関連機能を使用したときのみアクセスします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어시스턴트가 캘린더 이벤트를 보고, 만들고, 수정할 수 있도록 캘린더 접근을 사용합니다. 캘린더 데이터는 캘린더 관련 기능을 명시적으로 사용할 때만 접근합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们使用你的日历权限以提供数据给助手查看或修改。这些数据仅在明确请求时提供。"
          }
        }
      }
    },
    "We use your audio data for speech recognition. Your data is processed by system; we do not collect that information." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir nutzen deine Audiodaten für die Spracherkennung. Die Verarbeitung erfolgt systemseitig; wir sammeln diese Informationen nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use your audio data for speech recognition. Your data is processed by system, we do not collect those infomation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usamos tu audio para reconocimiento de voz. Lo procesa el sistema; no recopilamos esa información."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous utilisons vos données audio pour la reconnaissance vocale. Elles sont traitées par le système, nous ne les collectons pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声データは音声認識のために使用され、システムが処理します。私たちは収集しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음성 인식을 위해 오디오 데이터를 사용합니다. 데이터는 시스템에서 처리되며, 저희는 수집하지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要音频输入权限来进行听写。我们不会收集你的数据，但可能会被系统上传处理。"
          }
        }
      }
    },
    "We use your camera to take picture. Your photo may be uploaded by your choice." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir verwenden deine Kamera, um Fotos aufzunehmen. Das Foto kann auf deine Wahl hin hochgeladen werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use your camera to take picture. Your photo may be uploaded by your choice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usamos tu cámara para hacer fotos. La foto puede subirse si así lo decides."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous utilisons votre caméra pour prendre des photos. L’envoi de vos photos dépend de votre choix."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラを使用して写真を撮影します。アップロードするかはあなたの選択です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라를 사용해 사진을 촬영합니다. 업로드 여부는 사용자의 선택입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要相机权限来拍照。照片会按照你所请求的方式上传。"
          }
        }
      }
    },
    "We use your location data to provide location-based services when requested. Your location is only accessed when you explicitly use location-related features." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir nutzen deine Standortdaten für ortsbezogene Dienste auf Anfrage. Auf den Standort wird nur zugegriffen, wenn du Standortfunktionen ausdrücklich verwendest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use your location data to provide location-based services when requested. Your location is only accessed when you explicitly use location-related features."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usamos tu ubicación para servicios basados en ubicación cuando lo solicites. Solo se accede cuando uses funciones relacionadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous utilisons vos données de localisation pour fournir des services basés sur l’emplacement lorsque vous le demandez. La localisation n’est consultée que lors d’usages liés à cette fonctionnalité."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要求に応じ位置情報サービスを提供するため位置データを使用します。位置関連機能を使うときのみアクセスします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 기반 서비스 제공 시 위치 데이터를 사용합니다. 위치는 위치 관련 기능을 명시적으로 사용할 때만 접근합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们使用此权限提供定位数据。你的数据仅在明确请求时提供。"
          }
        }
      }
    },
